# Run the generic backend comparison group (interpreter/lowered).
backend-compare-generic:
    cd {{justfile_directory()}} && cargo bench -p laddu-core --bench expression_ir_benchmarks -- expression_ir_backend_microcomparisons --noplot

# Run the normalization backend comparison group (interpreter/lowered).
backend-compare-normalization:
    cd {{justfile_directory()}} && cargo bench -p laddu-core --bench expression_ir_benchmarks -- expression_ir_backend_normalization_microcomparisons --noplot

# Run the full backend comparison surface used for executor benchmarking.
backend-compare-full:
    just --justfile {{justfile()}} backend-compare-generic
    just --justfile {{justfile()}} backend-compare-normalization
